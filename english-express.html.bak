        <h1>Ship Eigo</h1>
        <!-- BGMボタン削除 -->
        <h2>レベル選択</h2>
        <div class="btn-group" id="level-buttons">
            <button class="btn-lvl" onclick="selectLevel(1)">📖 単語リスト (300語)</button>
        </div>
        <h2>出題形式</h2>
        <div class="btn-group" id="format-buttons">
            <button class="btn-mode selected" onclick="selectFormat('ja-typing')">和訳タイピング</button>
            <button class="btn-mode" onclick="selectFormat('en-typing')">英単語タイピング</button>
        </div>
        <h2>モード選択</h2>
        <div class="btn-group" id="mode-buttons">
            <button class="btn-mode selected" onclick="selectMode('practice')">練習モード（普通）</button>
            <button class="btn-mode" onclick="selectMode('memorization')">暗記モード（難しい）</button>
        </div>
        <h2>スピード選択</h2>
        <div class="btn-group" id="speed-buttons">
            <button class="btn-mode selected" onclick="selectSpeed(1.0)">通常</button>
            <button class="btn-mode" onclick="selectSpeed(1.5)">高速</button>
            <button class="btn-mode" onclick="selectSpeed(2.0)">超高速</button>
        </div>

        <div style="display:flex; flex-direction:column; gap:10px; align-items:center; margin-bottom: 20px;">
            <button class="btn-start" onclick="showPreview()">ゲームスタート</button>
            <div style="display:flex; gap:20px;">
                <button onclick="showHistory()"
                    style="background:transparent; border:none; color:#007bff; text-decoration:underline; cursor:pointer; font-size:0.9rem;">📊
                    学習履歴</button>
                <button onclick="openMyListModal()"
                    style="background:transparent; border:none; color:#007bff; text-decoration:underline; cursor:pointer; font-size:0.9rem;">📖
                    マイ単語リスト</button>
                <button onclick="openHelpModal()"
                    style="background:transparent; border:none; color:#007bff; text-decoration:underline; cursor:pointer; font-size:0.9rem;">📖
                    遊び方</button>
            </div>
        </div>

        <!-- 下部コンベア -->
        <div class="title-conveyor bottom">
            <div class="boxes-container">
                <div class="title-box" style="width:35px; margin-left:30px;"></div>
                <div class="title-box" style="width:42px; margin-left:70px;"></div>
                <div class="title-box" style="width:38px; margin-left:55px;"></div>
