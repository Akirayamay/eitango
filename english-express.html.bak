        // 自然・天気
        { en: "flower", ja: "はな", pos: "名詞" }, { en: "tree", ja: "き", pos: "名詞" },
        { en: "sun", ja: "たいよう", pos: "名詞" }, { en: "moon", ja: "つき", pos: "名詞" },
