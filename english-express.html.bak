                <div class="title-box" style="width:38px; margin-left:55px;"></div>
                <div class="title-box" style="width:33px; margin-left:90px;"></div>
                <div class="title-box" style="width:45px; margin-left:40px;"></div>
                <div class="title-box" style="width:36px; margin-left:80px;"></div>
                <div class="title-box" style="width:39px; margin-left:50px;"></div>
                <div class="title-box" style="width:34px; margin-left:95px;"></div>
