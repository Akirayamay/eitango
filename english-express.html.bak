    <div id="preview-screen" class="hidden">
        <div class="preview-content">
            <h1 class="preview-title"> 出題単語確認</h1>
            <div class="preview-subtitle">
                Level:<span id="preview-level">1</span> / <span id="preview-mode">練習モード</span>
            </div>
            <!-- ここにJSで動的にボタン類が挿入されますが、CSSで制御します -->

            <div id="word-list-container">
                <!-- 単語リスト -->
            </div>

            <div style="font-size: 0.8rem; color: #666; margin-bottom: 5px;">
                スペースキーでスタート
            </div>
            <button class="btn-start" onclick="startGame()">スタート！</button>
            <button class="btn-home" onclick="goHome()">タイトルに戻る</button>
        </div>
    </div>

    <div id="result-screen" class="hidden">
        <div class="result-content">
            <h2 class="result-title">結果発表！</h2>

            <div class="score-box">
                <div class="score-label">スコア</div>
                <div class="score-value" id="final-score">0</div>
                <div class="rank-display" id="final-rank"></div>
                <div style="display:flex; justify-content:space-around; margin-top:5px; font-size:0.8rem;">
                    <div>最大コンボ: <span id="final-combo" style="font-weight:bold;">0</span></div>
                    <div>正解率: <span id="final-accuracy" style="font-weight:bold;">0%</span></div>
                </div>
            </div>

            <div class="result-stats">
                <div>総単語数: <span id="total-count">0</span></div>
                <div style="color:var(--success-color)">正解: <span id="correct-count">0</span></div>
            </div>

            <!-- フィルターボタン -->
            <div class="filter-buttons" style="margin:15px 0 10px; display:flex; gap:5px; justify-content:center;">
                <button class="btn-filter selected" onclick="filterHistory('all')">すべて</button>
                <button class="btn-filter" onclick="filterHistory('perfect')">正解</button>
                <button class="btn-filter" onclick="filterHistory('suspicious')">怪しい</button>
                <button class="btn-filter" onclick="filterHistory('failed')">不正解</button>
            </div>

            <div id="word-history">
                <!-- 履歴リスト -->
            </div>

            <div style="display:flex; gap:10px; justify-content:center; flex-wrap:wrap; margin-top:10px;">
                <button class="btn-start" onclick="retryGame()" style="padding:10px 20px; font-size:1rem;">🔄
                    もう一度プレイ</button>
                <button class="btn-start" id="retry-mistakes-btn" onclick="retryMistakesOnly()"
                    style="padding:10px 20px; font-size:1rem; background:#ff6b35;">📝 間違えた・怪しい単語を復習</button>
                <button class="btn-home" onclick="goHome()" style="padding:10px 20px; font-size:1rem;">🏠
                    タイトルに戻る</button>
            </div>
        </div>
    </div>

    <!-- カスタム単語追加モーダル -->
    <div id="custom-word-modal" class="hidden"
        style="position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.7); display:flex; align-items:center; justify-content:center; z-index:1000;">
        <div
            style="background:white; padding:25px; border-radius:15px; max-width:550px; width:90%; height:85%; display:flex; flex-direction:column; box-shadow:0 10px 30px rgba(0,0,0,0.3);">
            <h3 style="margin:0 0 15px 0; color:#333; text-align:center;">📝 カスタム単語を追加</h3>

            <!-- タブボタン -->
            <div style="display:flex; border-bottom:1px solid #ddd; margin-bottom:15px;">
                <button id="tab-btn-manual" onclick="switchCustomTab('manual')"
                    style="flex:1; padding:10px; background:none; border:none; border-bottom:3px solid #28a745; font-weight:bold; cursor:pointer;">手動・一括入力</button>
                <button id="tab-btn-select" onclick="switchCustomTab('select')"
                    style="flex:1; padding:10px; background:none; border:none; border-bottom:3px solid transparent; color:#666; cursor:pointer;">リストから選択</button>
            </div>

            <!-- 手動入力タブ -->
            <div id="tab-manual" style="flex:1; display:flex; flex-direction:column; overflow-y:auto;">
                <div style="display:flex; flex-direction:column; gap:15px;">
                    <div>
                        <label style="font-weight:bold; display:block; margin-bottom:5px;">英単語</label>
                        <input type="text" id="custom-en" placeholder="例: hello"
                            style="width:100%; padding:10px; border:2px solid #ddd; border-radius:8px; font-size:1rem; box-sizing:border-box;">
                    </div>
                    <div>
                        <label style="font-weight:bold; display:block; margin-bottom:5px;">日本語（ひらがな）</label>
                        <input type="text" id="custom-ja" placeholder="例: こんにちは"
                            style="width:100%; padding:10px; border:2px solid #ddd; border-radius:8px; font-size:1rem; box-sizing:border-box;">
                    </div>
                    <div>
                        <label style="font-weight:bold; display:block; margin-bottom:5px;">品詞</label>
                        <select id="custom-pos"
                            style="width:100%; padding:10px; border:2px solid #ddd; border-radius:8px; font-size:1rem; box-sizing:border-box;">
                            <option value="名詞">名詞</option>
                            <option value="動詞">動詞</option>
                            <option value="形容詞">形容詞</option>
                            <option value="副詞">副詞</option>
                            <option value="その他">その他</option>
                        </select>
                    </div>
                    <div style="display:flex; gap:10px; justify-content:center; margin-top:10px;">
                        <button onclick="addCustomWord()"
                            style="padding:12px 25px; background:#28a745; color:white; border:none; border-radius:8px; font-size:1rem; cursor:pointer; font-weight:bold;">追加</button>
                    </div>
                </div>
                <div style="margin-top:15px; padding-top:15px; border-top:1px solid #eee;">
                    <div style="font-size:0.85rem; color:#666; text-align:center;">
                        <strong>一括追加:</strong> 複数の単語を一度に追加できます
                    </div>
                    <textarea id="bulk-add-text" placeholder="形式: 英単語,ひらがな,品詞&#10;例:&#10;hello,こんにちは,名詞&#10;run,はしる,動詞"
                        style="width:100%; height:80px; margin-top:10px; padding:8px; border:2px solid #ddd; border-radius:8px; font-size:0.85rem; box-sizing:border-box; resize:none;"></textarea>
                    <button onclick="bulkAddCustomWords()"
                        style="width:100%; margin-top:8px; padding:8px; background:#17a2b8; color:white; border:none; border-radius:8px; font-size:0.9rem; cursor:pointer;">一括追加</button>
                </div>
            </div>

            <!-- リスト選択タブ -->
            <div id="tab-select" class="hidden" style="flex:1; display:flex; flex-direction:column; overflow-y:hidden;">
                <div style="margin-bottom:10px; display:flex; flex-direction:column; gap:5px;">
                    <div style="display:flex; align-items:center; gap:10px;">
                        <label style="font-weight:bold; min-width:60px;">レベル:</label>
                        <select id="select-source-level" onchange="renderSourceWordList()"
                            style="padding:5px; border-radius:4px; border:1px solid #ddd; flex:1;">
                            <option value="1">Lv.1 小学生</option>
                            <option value="2">Lv.2 中学生</option>
                            <option value="3">Lv.3 高校生</option>
                            <option value="4">Lv.4 大学生</option>
                            <option value="5">Lv.5 日常会話</option>
                            <option value="6">Lv.6 TOEIC 700</option>
                            <option value="7">Lv.7 TOEIC 800</option>
                            <option value="9">Lv.9 金フレ730</option>
                        </select>
                    </div>
                    <div style="display:flex; align-items:center; gap:10px;">
                        <label style="font-weight:bold; min-width:60px;">品詞:</label>
                        <select id="select-source-pos" onchange="renderSourceWordList()"
                            style="padding:5px; border-radius:4px; border:1px solid #ddd; flex:1;">
                            <option value="all">すべて</option>
                            <option value="名詞">名詞</option>
                            <option value="動詞">動詞</option>
                            <option value="形容詞">形容詞</option>
                            <option value="副詞">副詞</option>
                            <option value="その他">その他</option>
                        </select>
                    </div>
                </div>
                <div style="display:flex; justify-content:space-between; margin-bottom:5px;">
                    <button onclick="selectAllSource()"
                        style="font-size:0.8rem; padding:2px 8px; cursor:pointer;">全選択</button>
                    <button onclick="deselectAllSource()"
                        style="font-size:0.8rem; padding:2px 8px; cursor:pointer;">全解除</button>
                </div>
                <div id="source-word-list"
                    style="flex:1; overflow-y:auto; border:1px solid #ddd; border-radius:8px; padding:5px;">
                    <!-- JSで描画 -->
                </div>
                <button onclick="addSelectedWordsFromSource()"
                    style="width:100%; margin-top:10px; padding:12px; background:#007bff; color:white; border:none; border-radius:8px; font-size:1rem; cursor:pointer; font-weight:bold;">選択した単語を追加</button>
            </div>

            <div
                style="display:flex; justify-content:center; margin-top:15px; padding-top:10px; border-top:1px solid #eee;">
                <button onclick="closeCustomModal()"
                    style="padding:10px 25px; background:#6c757d; color:white; border:none; border-radius:8px; font-size:1rem; cursor:pointer; font-weight:bold;">閉じる</button>
            </div>
        </div>
    </div>

    <!-- 学習履歴モーダル -->
    <div id="history-modal" class="hidden"
        style="position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.7); display:flex; align-items:center; justify-content:center; z-index:1000;">
        <div
            style="background:white; padding:25px; border-radius:15px; max-width:600px; width:90%; height:80%; display:flex; flex-direction:column; box-shadow:0 10px 30px rgba(0,0,0,0.3);">
            <h3 style="margin:0 0 10px 0; color:#333; text-align:center;">📊 学習履歴</h3>

            <!-- 履歴切り替えタブ -->
            <div
                style="display:flex; justify-content:center; gap:10px; margin-bottom:15px; border-bottom:1px solid #ddd; padding-bottom:5px;">
                <button id="hist-tab-ja" onclick="switchHistoryTab('ja-typing')"
                    style="background:none; border:none; border-bottom:3px solid #007bff; font-weight:bold; padding:5px 10px; cursor:pointer; color:#007bff;">
                    和訳タイピング
                </button>
                <button id="hist-tab-en" onclick="switchHistoryTab('en-typing')"
                    style="background:none; border:none; border-bottom:3px solid transparent; font-weight:bold; padding:5px 10px; cursor:pointer; color:#666;">
                    英単語タイピング
                </button>
            </div>

            <div
                style="display:flex; justify-content:space-around; margin-bottom:15px; background:#f8f9fa; padding:10px; border-radius:8px;">
                <div style="text-align:center;">
                    <div style="font-size:0.8rem; color:#666;">総プレイ</div>
                    <div style="font-weight:bold; font-size:1.1rem;" id="hist-total-sessions">0</div>
                </div>
                <div style="text-align:center;">
                    <div style="font-size:0.8rem; color:#666;">平均正解率</div>
                    <div style="font-weight:bold; font-size:1.1rem;" id="hist-avg-accuracy">0%</div>
                </div>
                <div style="text-align:center;">
                    <div style="font-size:0.8rem; color:#666;">累計スコア</div>
                    <div style="font-weight:bold; font-size:1.1rem;" id="hist-total-score">0</div>
                </div>
            </div>

            <!-- 苦手単語リスト -->
            <h4 style="margin:0 0 10px 0; color:#555;">⚠️ 苦手な単語（トップ10）</h4>
            <div id="weak-words-list"
                style="height:150px; overflow-y:auto; margin-bottom:15px; border:1px solid #eee; border-radius:8px; padding:5px;">
                <!-- JS生成 -->
            </div>

            <!-- プレイ履歴リスト -->
            <h4 style="margin:0 0 10px 0; color:#555;">📜 プレイ履歴（最新50件）</h4>
            <div id="play-history-list"
                style="height:150px; overflow-y:auto; margin-bottom:15px; border:1px solid #eee; border-radius:8px; padding:5px;">
                <!-- JS生成 -->
            </div>

            <div style="display:flex; gap:10px; justify-content:center; flex-wrap:wrap;">
                <button onclick="clearHistoryData()"
                    style="padding:10px 15px; background:#dc3545; color:white; border:none; border-radius:8px; font-size:0.9rem; cursor:pointer;">🗑️
                    履歴・苦手を消去</button>
                <button onclick="closeHistoryModal()"
                    style="padding:10px 25px; background:#6c757d; color:white; border:none; border-radius:8px; font-size:1rem; cursor:pointer; font-weight:bold;">閉じる</button>
            </div>
        </div>
    </div>

    <!-- 遊び方・ルールモーダル -->
    <div id="help-modal" class="hidden"
        style="position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.7); display:flex; align-items:center; justify-content:center; z-index:2000;">
        <div
            style="background:white; padding:30px; border-radius:15px; max-width:600px; width:90%; max-height:90vh; overflow-y:auto; box-shadow:0 10px 30px rgba(0,0,0,0.3); position:relative;">
            <button onclick="closeHelpModal()"
                style="position:absolute; top:15px; right:15px; background:none; border:none; font-size:1.5rem; cursor:pointer; color:#666;">×</button>
            <h2 style="text-align:center; color:#333; margin-top:0; border-bottom:2px solid #eee; padding-bottom:10px;">
                📖
                Ship Eigo の遊び方</h2>

            <div style="margin-top:20px; line-height:1.6; color:#444;">
                <h3 style="color:#007bff; margin-bottom:10px;">🎯 ゲームの目的</h3>
                <p>ベルトコンベアに乗って流れてくる段ボールに書かれた英単語をタイピングして、制限時間内に出荷しよう！</p>

                <h3 style="color:#28a745; margin-bottom:10px;">🎮 操作方法</h3>
                <ul style="padding-left:20px;">
                    <li>画面に表示されるローマ字をキーボードで入力してください。</li>
                    <li>入力が完了すると自動的に出荷されます（Enterキーは不要です）。</li>
                    <li>「ん」は <code>nn</code> または <code>n</code>（次が子音の場合）で入力可能です。</li>
                </ul>

                <h3 style="color:#dc3545; margin-bottom:10px;">⚠️ 注意点</h3>
                <ul style="padding-left:20px;">
                    <li>タイプミスをしたり、段ボールが画面外に流れてしまうと「失敗」になります。</li>
                    <li>失敗するとコンボが途切れてしまいます。</li>
                </ul>

                <h3 style="color:#fd7e14; margin-bottom:10px;">🛠️ その他の機能</h3>
                <ul style="padding-left:20px;">
                    <li><strong>暗記モード:</strong> 時間経過で日本語が消える高難易度モードです。</li>
                    <li><strong>金フレ730:</strong> 「出る単特急 金のフレーズ」のスコア730レベル300語を収録。TOEIC対策に最適！</li>
                    <li><strong>カスタム単語:</strong> 📝カスタムを選択すると、自分で登録した単語で遊べます。</li>
                    <li><strong>スピード調整:</strong> 自分に合った速度で練習できます。</li>
                </ul>
            </div>

            <div style="text-align:center; margin-top:30px;">
                <button onclick="closeHelpModal()"
                    style="background:#007bff; color:white; border:none; padding:10px 30px; border-radius:30px; font-size:1.1rem; cursor:pointer; box-shadow:0 4px 10px rgba(0,123,255,0.3);">閉じる</button>
            </div>
        </div>
    </div>

    <!-- マイ単語リストモーダル -->
    <div id="mylist-modal" class="hidden"
        style="position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.7); display:flex; align-items:center; justify-content:center; z-index:1000;">
        <div
            style="background:white; padding:25px; border-radius:15px; max-width:600px; width:90%; height:80%; display:flex; flex-direction:column; box-shadow:0 10px 30px rgba(0,0,0,0.3);">
            <h3 style="margin:0 0 10px 0; color:#333; text-align:center;">📖 マイ単語リスト</h3>
            <div style="font-size:0.85rem; color:#666; text-align:center; margin-bottom:10px;">
                気になる単語を登録して、自分だけのリストを作ろう！
            </div>
            <div id="mylist-container"
                style="flex:1; overflow-y:auto; margin-bottom:15px; border:1px solid #eee; border-radius:8px; padding:5px; background: #f9f9f9;">
                <!-- JS生成 -->
            </div>
            <div style="display:flex; gap:10px; justify-content:center; flex-wrap:wrap;">
                <button onclick="startMyListGame()"
                    style="padding:12px 25px; background:var(--success-color); color:white; border:none; border-radius:8px; font-size:1rem; cursor:pointer; font-weight:bold; box-shadow: 0 3px 5px rgba(0,0,0,0.2);">🎮
                    このリストで遊ぶ</button>
                <button onclick="closeMyListModal()"
                    style="padding:10px 25px; background:#6c757d; color:white; border:none; border-radius:8px; font-size:1rem; cursor:pointer; font-weight:bold;">閉じる</button>
            </div>
        </div>
    </div>

    <!-- トースト通知コンテナ -->
    <div id="toast-container"></div>

    <!-- 外部単語リストの読み込み -->
    <script src="wordList.js"></script>

    <script>
        // ===== 柔軟ローマ字変換テーブル =====
        const kanaMap = {
            'あ': ['a'], 'い': ['i'], 'う': ['u'], 'え': ['e'], 'お': ['o'],
            'か': ['ka', 'ca'], 'き': ['ki'], 'く': ['ku', 'cu', 'qu'], 'け': ['ke'], 'こ': ['ko', 'co'],
            'きゃ': ['kya'], 'きゅ': ['kyu'], 'きょ': ['kyo'],
            'さ': ['sa'], 'し': ['si', 'shi', 'ci'], 'す': ['su'], 'せ': ['se', 'ce'], 'そ': ['so'],
            'しゃ': ['sya', 'sha'], 'しゅ': ['syu', 'shu'], 'しょ': ['syo', 'sho'], 'しぇ': ['sye', 'she'],
            'た': ['ta'], 'ち': ['ti', 'chi'], 'つ': ['tu', 'tsu'], 'て': ['te'], 'と': ['to'],
            'ちゃ': ['tya', 'cha', 'cya'], 'ちゅ': ['tyu', 'chu', 'cyu'], 'ちょ': ['tyo', 'cho', 'cyo'],
            'な': ['na'], 'に': ['ni'], 'ぬ': ['nu'], 'ね': ['ne'], 'の': ['no'],
            'にゃ': ['nya'], 'にゅ': ['nyu'], 'にょ': ['nyo'],
            'は': ['ha'], 'ひ': ['hi'], 'ふ': ['hu', 'fu'], 'へ': ['he'], 'ほ': ['ho'],
            'ひゃ': ['hya'], 'ひゅ': ['hyu'], 'ひょ': ['hyo'],
            'ま': ['ma'], 'み': ['mi'], 'む': ['mu'], 'め': ['me'], 'も': ['mo'],
            'みゃ': ['mya'], 'みゅ': ['myu'], 'みょ': ['myo'],
            'や': ['ya'], 'ゆ': ['yu'], 'よ': ['yo'],
            'ら': ['ra', 'la'], 'り': ['ri', 'li'], 'る': ['ru', 'lu'], 'れ': ['re', 'le'], 'ろ': ['ro', 'lo'],
            'りゃ': ['rya', 'lya'], 'りゅ': ['ryu', 'lyu'], 'りょ': ['ryo', 'lyo'],
            'わ': ['wa'], 'を': ['wo'], 'ん': ['nn'],
            'が': ['ga'], 'ぎ': ['gi'], 'ぐ': ['gu'], 'げ': ['ge'], 'ご': ['go'],
            'ぎゃ': ['gya'], 'ぎゅ': ['gyu'], 'ぎょ': ['gyo'],
            'ざ': ['za'], 'じ': ['zi', 'ji'], 'ず': ['zu'], 'ぜ': ['ze'], 'ぞ': ['zo'],
            'じゃ': ['zya', 'ja', 'jya'], 'じゅ': ['zyu', 'ju', 'jyu'], 'じょ': ['zyo', 'jo', 'jyo'],
            'だ': ['da'], 'ぢ': ['di'], 'づ': ['du', 'dzu'], 'で': ['de'], 'ど': ['do'],
            'ば': ['ba'], 'び': ['bi'], 'ぶ': ['bu'], 'べ': ['be'], 'ぼ': ['bo'],
            'びゃ': ['bya'], 'びゅ': ['byu'], 'びょ': ['byo'],
            'ぱ': ['pa'], 'ぴ': ['pi'], 'ぷ': ['pu'], 'ぺ': ['pe'], 'ぽ': ['po'],
            'ぴゃ': ['pya'], 'ぴゅ': ['pyu'], 'ぴょ': ['pyo'],
            'ぁ': ['xa', 'la'], 'ぃ': ['xi', 'li'], 'ぅ': ['xu', 'lu'], 'ぇ': ['xe', 'le'], 'ぉ': ['xo', 'lo'],
            'ゃ': ['xya', 'lya'], 'ゅ': ['xyu', 'lyu'], 'ょ': ['xyo', 'lyo'],
            'っ': ['xtu', 'ltu', 'xtsu', 'ltsu'],
            'ー': ['-'],
            'うぇ': ['we', 'uxe', 'ule'],
            'てぃ': ['thi', 'txi', 'tli', 'texi', 'teli'],
            'すぽ': ['supo'], 'ぽー': ['po-']
        };

        // ===== ひらがな解析 =====
        function parseHiragana(hiragana) {
            const chunks = [];
            let i = 0;
            while (i < hiragana.length) {
                // 促音（っ）の処理
                if (hiragana[i] === 'っ' && i + 1 < hiragana.length) {
                    let nextKana = hiragana[i + 1];
                    if (i + 2 < hiragana.length && kanaMap[hiragana.substring(i + 1, i + 3)]) {
                        nextKana = hiragana.substring(i + 1, i + 3);
                    }
                    const nextPatterns = kanaMap[nextKana] || [nextKana];
                    const sokuonPatterns = nextPatterns.map(p => p[0]);
                    chunks.push({ kana: 'っ', patterns: [...new Set([...sokuonPatterns, 'xtu', 'ltu', 'xtsu', 'ltsu'])], isSokuon: true });
                    i++;
                    continue;
                }
                // 2文字（拗音など）を先にチェック
                if (i + 1 < hiragana.length) {
                    const twoChars = hiragana.substring(i, i + 2);
                    if (kanaMap[twoChars]) {
                        chunks.push({ kana: twoChars, patterns: kanaMap[twoChars] });
                        i += 2;
                        continue;
                    }
                }
                // 1文字処理
                const oneChar = hiragana[i];
                if (kanaMap[oneChar]) {
                    chunks.push({ kana: oneChar, patterns: kanaMap[oneChar] });
                } else {
                    chunks.push({ kana: oneChar, patterns: [oneChar.toLowerCase()] });
                }
                i++;
            }
            return chunks;
        }

        // ===== タイピング状態クラス =====
        class TypingState {
            constructor(targetStr, isEnglishMode = false) {
                this.isEnglishMode = isEnglishMode;
                if (isEnglishMode) {
                    // 英単語モード
                    this.chunks = targetStr.split('').map(char => ({
                        kana: char,
                        patterns: [char.toLowerCase()]
                    }));
                } else {
                    // 和訳モード
                    this.chunks = parseHiragana(targetStr);
                }
                this.chunkIndex = 0;
                this.completedRomaji = '';
                this.currentInput = '';
                this.pendingPatterns = [];
                this.updatePendingPatterns();
            }
            updatePendingPatterns() {
                if (this.chunkIndex >= this.chunks.length) {
                    this.pendingPatterns = [];
                    return;
                }
                const chunk = this.chunks[this.chunkIndex];

                if (this.isEnglishMode) {
                    this.pendingPatterns = chunk.patterns;
                    return;
                }

                let patterns = [];
                if (chunk.patterns) patterns = [...chunk.patterns];

                // 「ん」の特殊処理
                if (chunk.kana === 'ん') {
                    patterns = ['nn', 'xn'];
                }

                // 促音の処理
                if (chunk.isSokuon && this.chunks[this.chunkIndex + 1]) {
                    const nextPatterns = this.chunks[this.chunkIndex + 1].patterns;
                    patterns = [...new Set([...nextPatterns.map(p => p[0]), 'xtu', 'ltu', 'xtsu', 'ltsu'])];
                }

                this.pendingPatterns = patterns;
            }
            processInput(char) {
                const inputChar = char.toLowerCase();
                const testInput = this.currentInput + inputChar;
                // 前方一致するパターンをフィルタリング
                const matchingPatterns = this.pendingPatterns.filter(p => p.startsWith(testInput));
                if (matchingPatterns.length === 0) {
                    return { success: false, completed: false };
                }
                this.currentInput = testInput;
                // 完全一致するパターンがあればチャンク完了
                const exactMatch = matchingPatterns.find(p => p === testInput);
                if (exactMatch) {
                    this.completedRomaji += testInput;
                    this.currentInput = '';
                    this.chunkIndex++;
                    this.updatePendingPatterns();
                    return { success: true, completed: this.chunkIndex >= this.chunks.length };
                }
                return { success: true, completed: false };
            }
            getDisplayInfo() {
                const typed = this.completedRomaji;
                const current = this.currentInput;
                let remaining = '';
                if (this.chunkIndex < this.chunks.length) {
                    const firstPattern = this.pendingPatterns[0] || '';
                    remaining = firstPattern.substring(this.currentInput.length);
                    for (let i = this.chunkIndex + 1; i < this.chunks.length; i++) {
                        const c = this.chunks[i];
                        if (c.kana === 'ん') remaining += 'nn';
                        else remaining += c.patterns[0] || '';
                    }
                }
                return { typed, current, remaining };
            }
        }

        // ===== 単語データ（jaのみで判定） =====
        // ===== 単語データ =====
        // 外部ファイル wordList.js の newWordList を使用
        const wordData = {
            1: newWordList
        };


